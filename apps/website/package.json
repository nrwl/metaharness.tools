{
  "name": "website",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@metaharness/animations": "workspace:*",
    "astro": "^7.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@swc-node/register": "^1.11.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "node-html-parser": "^9.0.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.3",
    "wawoff2": "^2.0.1"
  },
  "nx": {
    "targets": {
      "og": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/public/og.png"
        ],
        "inputs": [
          "{projectRoot}/tools/og/**/*",
          "{projectRoot}/package.json",
          "{workspaceRoot}/pnpm-lock.yaml"
        ],
        "options": {
          "command": "cd apps/website && node --import @swc-node/register/esm-register tools/og/generate-og.mts"
        }
      },
      "build": {
        "dependsOn": [
          "^build",
          "og"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ],
        "inputs": [
          "production",
          "^production",
          {
            "env": "COMING_SOON"
          }
        ]
      }
    }
  }
}
