---
const resources = [
  {
    label: 'Stanford, Meta-Harness',
    href: 'https://arxiv.org/abs/2603.28052',
    body: 'The harness-optimization paper: an outer loop that searches over the harness around an LLM.',
  },
  {
    label: 'Martin Fowler, Harness Engineering',
    href: 'https://martinfowler.com/articles/harness-engineering.html',
    body: 'A foundational treatment of the harness as an engineering discipline.',
  },
  {
    label: 'Anthropic, Managed Agents',
    href: 'https://www.anthropic.com/engineering/managed-agents',
    body: 'A meta-harness that decouples brain, hands, and session so harnesses stay swappable.',
  },
  {
    label: 'Firecrawl, What is an Agent Harness',
    href: 'https://www.firecrawl.dev/blog/what-is-an-agent-harness',
    body: 'An accessible introduction to the harness concept.',
  },
  {
    label: 'Databricks, Introducing Omnigent',
    href: 'https://www.databricks.com/blog/introducing-omnigent-meta-harness-combine-control-and-share-your-agents',
    body: 'The announcement of Omnigent: a runner-plus-server meta-harness for composing, governing, and sharing agents.',
  },
  {
    label: 'Agent Client Protocol',
    href: 'https://agentclientprotocol.com/get-started/agents',
    body: 'A protocol that standardizes the editor-to-agent boundary.',
  },
  {
    label: 'Flue Framework',
    href: 'https://flueframework.com/',
    body: 'A framework for durable, resumable agent execution a meta-harness can build on.',
  },
];
---

<section id="resources" class="px-6 py-20 md:py-28">
  <div class="mx-auto max-w-5xl">
    <h2
      class="text-4xl font-semibold tracking-tight text-neutral-900 sm:text-5xl dark:text-neutral-50"
    >
      Resources
    </h2>

    <ul class="mt-10 grid gap-x-12 sm:grid-cols-2">
      {
        resources.map((r) => (
          <li>
            <a
              href={r.href}
              target="_blank"
              rel="noopener"
              class="group flex flex-col gap-1 border-t border-neutral-200 py-5 dark:border-neutral-900"
            >
              <span class="text-base font-medium text-neutral-900 transition-colors group-hover:text-accent dark:text-neutral-100">
                {r.label}
              </span>
              <span class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-500">
                {r.body}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
