---
const resources = [
  {
    label: 'Stanford, Meta-Harness',
    href: 'https://arxiv.org/abs/2603.28052',
    body: 'The harness-optimization paper: an outer loop that searches over the harness around an LLM.',
  },
  {
    label: 'Martin Fowler, Harness Engineering',
    href: 'https://martinfowler.com/articles/harness-engineering.html',
    body: 'A foundational treatment of the harness as an engineering discipline.',
  },
  {
    label: 'Anthropic, Managed Agents',
    href: 'https://www.anthropic.com/engineering/managed-agents',
    body: 'A meta-harness that decouples brain, hands, and session so harnesses stay swappable.',
  },
  {
    label: 'Firecrawl, What is an Agent Harness',
    href: 'https://www.firecrawl.dev/blog/what-is-an-agent-harness',
    body: 'An accessible introduction to the harness concept.',
  },
  {
    label: 'Databricks, Omnigent (repository)',
    href: 'https://github.com/omnigent-ai/omnigent',
    body: 'The open-source implementation of the Databricks Omnigent meta-harness.',
  },
  {
    label: 'SuperagenticAI, metaharness',
    href: 'https://github.com/SuperagenticAI/metaharness',
    body: 'An unofficial harness optimizer for coding agents, inspired by the Stanford paper.',
  },
  {
    label: 'Agent Client Protocol',
    href: 'https://agentclientprotocol.com/get-started/agents',
    body: 'A protocol that standardizes the editor-to-agent boundary.',
  },
  {
    label: 'Flue Framework',
    href: 'https://flueframework.com/',
    body: 'A framework for durable, resumable agent execution a meta-harness can build on.',
  },
];
---

<section id="polygraph" class="px-6 py-20 md:py-28">
  <div class="mx-auto max-w-3xl">
    <div
      class="rounded-xl border border-neutral-300 bg-neutral-100/60 p-8 sm:p-10 dark:border-neutral-800 dark:bg-neutral-900/40"
    >
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-accent">
        A meta-harness by Nx
      </p>
      <h2 class="mt-4">
        <img
          src="/images/polygraph-lockup-light-bg.svg"
          alt="Polygraph"
          width="678"
          height="137"
          class="block h-8 w-auto sm:h-9 dark:hidden"
        />
        <img
          src="/images/polygraph-lockup-dark-bg.svg"
          alt="Polygraph"
          width="678"
          height="137"
          class="hidden h-8 w-auto sm:h-9 dark:block"
        />
      </h2>
      <p
        class="mt-5 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      >
        Polygraph is a meta-harness. It dissolves repo and session boundaries,
        giving your agents a unified dependency graph across your organization
        without moving any code, durable sessions anyone can resume, and
        institutional memory that carries from one session to the next.
        Polygraph isn't an agent. It's infrastructure that makes your agents
        more powerful.
      </p>
      <a
        href="https://trypolygraph.com"
        target="_blank"
        rel="noopener"
        class="mt-8 inline-flex items-center gap-2 rounded-md border border-neutral-300 bg-neutral-900 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-neutral-700 dark:border-neutral-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-white"
      >
        Explore Polygraph
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>

  <div class="mx-auto mt-20 max-w-3xl">
    <h2
      class="text-2xl font-semibold tracking-tight text-neutral-900 sm:text-3xl dark:text-neutral-50"
    >
      Resources
    </h2>

    <ul
      class="mt-8 divide-y divide-neutral-200 border-t border-neutral-200 dark:divide-neutral-900 dark:border-neutral-900"
    >
      {
        resources.map((r) => (
          <li class="py-5">
            <a
              href={r.href}
              target="_blank"
              rel="noopener"
              class="group flex flex-col gap-1"
            >
              <span class="text-base font-medium text-neutral-900 transition-colors group-hover:text-accent dark:text-neutral-100">
                {r.label}
              </span>
              <span class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-500">
                {r.body}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
