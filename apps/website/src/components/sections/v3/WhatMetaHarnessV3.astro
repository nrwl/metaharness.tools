---
import {
  CrossRepoShip,
  FeedbackLoop,
  HarnessSwapDiagram,
  PolicyGate,
  ProvisioningSetup,
  RepositoryGraph,
  SessionDurability,
  SessionTimeline,
} from '@metaharness/animations';
import VizSurface from '../../VizSurface.astro';
import VizPlaceholder from '../../VizPlaceholder.astro';

const capabilities: {
  title: string;
  body: string;
  island?: string;
  viz?: string;
}[] = [
  {
    title: 'Work across repositories at once',
    body: 'Agents edit several repos in parallel and open coordinated PRs, so the changes land together instead of breaking each other.',
    island: 'cross-repo-ship',
  },
  {
    title: 'Session durability',
    body: 'Sessions are captured, stored, and indexed for search, so agents can resume them or pull them in as context instead of starting cold.',
    island: 'session-durability',
  },
  {
    title: 'Multiplayer and collaboration',
    body: "Shared, resumable sessions let you build on a coworker's, turning individual runs into org-wide memory.",
    island: 'session-timeline',
  },
  {
    title: 'Organizational rules and policies',
    body: "Policy lives at the meta-harness layer, checking prompts, tools, and actions against your organization's rules in code.",
    island: 'policy-gate',
  },
  {
    title: 'Feedback loops',
    body: 'Wrap act, verify, and correct loops around your harness, from a single goal-driven run to scheduled and event-driven loops.',
    island: 'feedback-loop',
  },
];
---

<section id="capabilities" class="px-6 py-20 md:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">
        Capabilities
      </p>
      <h2
        class="mt-4 text-3xl font-semibold tracking-tight text-neutral-900 sm:text-4xl dark:text-neutral-50"
      >
        Possible meta-harness capabilities
      </h2>
      <p
        class="mt-6 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      >
        The meta-harness is still a broad, fast-moving idea. There is no single
        fixed definition yet, and
        <strong class="font-semibold text-neutral-900 dark:text-neutral-50"
          >the exact properties depend on the type of meta-harness and the scope
          it takes on.</strong
        >
      </p>
      <p
        class="mt-6 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      >
        Right now the term is used in two ways.{' '}
        <strong class="font-semibold text-neutral-900 dark:text-neutral-50"
          >Harness optimization</strong
        >
        {' '}is the Stanford Meta-Harness usage: an outer-loop system searches
        over the harness around an LLM, tuning prompts, memory, retrieval,
        context formatting, tools, completion checks, and runtime code.
      </p>
      <p
        class="mt-6 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      >
        <strong class="font-semibold text-neutral-900 dark:text-neutral-50"
          >Harness orchestration</strong
        >
        {' '}is the industry usage: a control layer sits above many agent
        harnesses and handles routing, composition, sandboxing, policy,
        observability, and collaboration.
      </p>
    </div>

    <div class="mx-auto mt-16 flex max-w-3xl items-center gap-6">
      <span
        class="h-px flex-1 bg-neutral-300 dark:bg-neutral-800"
        aria-hidden="true"></span>
      <p
        class="text-center text-2xl italic text-neutral-700 dark:text-neutral-200"
      >
        Here are some of the potential capabilities.
      </p>
      <span
        class="h-px flex-1 bg-neutral-300 dark:bg-neutral-800"
        aria-hidden="true"></span>
    </div>

    <div class="mt-12 space-y-12">
      <div
        class="grid min-w-0 items-center gap-10 pt-2 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)]"
      >
        <div>
          <h3
            class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            Swappable harnesses
          </h3>
          <p
            class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400"
          >
            Wraps Claude Code, Codex, or OpenCode instead of replacing them, so
            the harness underneath stays swappable.
          </p>
        </div>

        <!-- interim: dark surface until Phase 2 DOM animations -->
        <VizSurface aspect="none">
          <HarnessSwapDiagram client:visible />
        </VizSurface>
      </div>

      <div
        class="grid min-w-0 items-center gap-10 border-t border-neutral-200 pt-12 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)] dark:border-neutral-900"
      >
        <div>
          <h3
            class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            Repository knowledge
          </h3>
          <p
            class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400"
          >
            The agent gets a map of the whole system: which repositories exist,
            how they relate, and where a change belongs.
          </p>
        </div>

        <!-- interim: dark surface until Phase 2 DOM animations -->
        <VizSurface>
          <RepositoryGraph client:visible className="mx-auto" />
        </VizSurface>
      </div>

      <div
        class="grid min-w-0 items-center gap-10 border-t border-neutral-200 pt-12 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)] dark:border-neutral-900"
      >
        <div>
          <h3
            class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            Provisioning and setup
          </h3>
          <p
            class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400"
          >
            It provisions the repos an agent needs, clones them into isolated
            worktrees, and runs the setup scripts before work starts.
          </p>
        </div>

        <!-- interim: dark surface until Phase 2 DOM animations -->
        <VizSurface aspect="none">
          <ProvisioningSetup client:visible className="mx-auto" />
        </VizSurface>
      </div>

      {
        capabilities.map((item) => (
          <div class="grid min-w-0 items-center gap-10 border-t border-neutral-200 pt-12 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)] dark:border-neutral-900">
            <div>
              <h3 class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50">
                {item.title}
              </h3>
              <p class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
                {item.body}
              </p>
            </div>

            {item.island === 'cross-repo-ship' ? (
              <VizSurface aspect="none">
                <CrossRepoShip client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'session-timeline' ? (
              <VizSurface>
                <SessionTimeline client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'session-durability' ? (
              <VizSurface>
                <SessionDurability client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'feedback-loop' ? (
              <VizSurface aspect="none">
                <FeedbackLoop client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'policy-gate' ? (
              <VizSurface aspect="none">
                <PolicyGate client:visible className="mx-auto" />
              </VizSurface>
            ) : (
              <VizPlaceholder label={item.viz ?? ''} ratio="aspect-[16/9]" />
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
