---
import {
  CrossRepoShip,
  FeedbackLoop,
  HarnessSwapDiagram,
  MemoryDistill,
  PolicyGate,
  ProvisioningSetup,
  RepositoryGraph,
  SessionDurability,
  SessionTimeline,
} from '@metaharness/animations';
import VizSurface from '../../VizSurface.astro';
import VizPlaceholder from '../../VizPlaceholder.astro';

// Lucide-style icons (24x24, stroke currentColor). Rendered inline before each subtitle.
const icons: Record<string, string> = {
  swap: '<path d="M17 2l4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="M7 22l-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/>',
  graph:
    '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  server:
    '<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>',
  merge:
    '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>',
  database:
    '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/>',
  users:
    '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  brain:
    '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/>',
  shield:
    '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
  loop: '<path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/>',
};

const renderIcon = (name: string) =>
  `<svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${icons[name]}</svg>`;

const capabilities: {
  title: string;
  body: string;
  icon: string;
  island?: string;
  viz?: string;
}[] = [
  {
    title: 'Work across repositories at once',
    body: 'Agents edit several repos in parallel and open coordinated PRs, so the changes land together instead of breaking each other.',
    icon: 'merge',
    island: 'cross-repo-ship',
  },
  {
    title: 'Session durability',
    body: 'Sessions are captured, stored, and indexed for search, so agents can resume them or pull them in as context instead of starting cold.',
    icon: 'database',
    island: 'session-durability',
  },
  {
    title: 'Multiplayer and collaboration',
    body: "Shared, resumable sessions let you build on a coworker's, turning individual runs into org-wide memory.",
    icon: 'users',
    island: 'session-timeline',
  },
  {
    title: 'Distilled memory',
    body: 'The meta-harness can steer processes like "dreaming": offline passes that consolidate finished session runs into a shared pool of general knowledge. Future sessions connect to it and start with what earlier ones learned instead of from a cold context.',
    icon: 'brain',
    island: 'memory-distill',
  },
  {
    title: 'Organizational rules and policies',
    body: "Policy lives at the meta-harness layer, checking prompts, tools, and actions against your organization's rules in code.",
    icon: 'shield',
    island: 'policy-gate',
  },
  {
    title: 'Feedback loops',
    body: 'Wrap act, verify, and correct loops around your harness, from a single goal-driven run to scheduled and event-driven loops.',
    icon: 'loop',
    island: 'feedback-loop',
  },
];
---

<section id="capabilities" class="px-6 py-20 md:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      <h2
        class="text-4xl font-semibold tracking-tight text-neutral-900 sm:text-5xl dark:text-neutral-50"
      >
        Meta-harness capabilities
      </h2>
      <p
        class="mt-6 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      >
        The meta-harness is still a broad, fast-moving idea, and right now it's
        used in two ways.
      </p>

      <div class="mt-10 space-y-8">
        <div>
          <h3
            class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            <span
              class="h-2 w-2 shrink-0 rounded-[2px] bg-accent"
              aria-hidden="true"></span>
            Harness optimization
          </h3>
          <p
            class="mt-3 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
          >
            The Stanford Meta-Harness sense, and the one this site focuses on: an
            outer-loop system searches over the harness around an LLM (prompts,
            memory, retrieval, context, tools, completion checks) and keeps what
            works, so agentic work compounds over time instead of resetting each
            session.
          </p>
        </div>
        <div>
          <h3
            class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            <span
              class="h-2 w-2 shrink-0 rounded-[2px] bg-accent"
              aria-hidden="true"></span>
            Harness orchestration
          </h3>
          <p
            class="mt-3 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
          >
            A parallel industry sense: a control layer above many agent harnesses
            that handles routing, composition, sandboxing, and policy. Related,
            but not the focus here.
          </p>
        </div>
      </div>
    </div>

    <div class="mx-auto mt-16 flex max-w-3xl items-center gap-6">
      <span
        class="h-px flex-1 bg-neutral-300 dark:bg-neutral-800"
        aria-hidden="true"></span>
      <p
        class="text-center text-2xl italic text-neutral-700 dark:text-neutral-200"
      >
        Here are some of the potential capabilities.
      </p>
      <span
        class="h-px flex-1 bg-neutral-300 dark:bg-neutral-800"
        aria-hidden="true"></span>
    </div>

    <div class="mt-12 space-y-12">
      <div
        class="grid min-w-0 items-center gap-10 pt-2 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)]"
      >
        <div>
          <h3
            class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            <span class="text-accent" set:html={renderIcon('swap')} />
            Swappable harnesses
          </h3>
          <p
            class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400"
          >
            The harness is never locked in. Resume the same session on Claude
            Code, Codex, or OpenCode, switching agents whenever another one fits
            the task better.
          </p>
        </div>

        <VizSurface aspect="none">
          <HarnessSwapDiagram client:visible />
        </VizSurface>
      </div>

      <div
        class="grid min-w-0 items-center gap-10 border-t border-neutral-200 pt-12 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)] dark:border-neutral-900"
      >
        <div>
          <h3
            class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            <span class="text-accent" set:html={renderIcon('graph')} />
            Repository knowledge
          </h3>
          <p
            class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400"
          >
            The agent works with added context about the landscape around it:
            which repositories exist, how they relate, and where a change
            belongs.
          </p>
        </div>

        <VizSurface>
          <RepositoryGraph client:visible className="mx-auto" />
        </VizSurface>
      </div>

      <div
        class="grid min-w-0 items-center gap-10 border-t border-neutral-200 pt-12 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)] dark:border-neutral-900"
      >
        <div>
          <h3
            class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50"
          >
            <span class="text-accent" set:html={renderIcon('server')} />
            Provisioning and setup
          </h3>
          <p
            class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400"
          >
            It provisions the repos an agent needs, clones them into isolated
            worktrees, and runs the setup scripts before work starts.
          </p>
        </div>

        <VizSurface aspect="none">
          <ProvisioningSetup client:visible className="mx-auto" />
        </VizSurface>
      </div>

      {
        capabilities.map((item) => (
          <div class="grid min-w-0 items-center gap-10 border-t border-neutral-200 pt-12 lg:grid-cols-[minmax(0,20rem)_minmax(0,1fr)] dark:border-neutral-900">
            <div>
              <h3 class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-50">
                <span class="text-accent" set:html={renderIcon(item.icon)} />
                {item.title}
              </h3>
              <p class="mt-3 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
                {item.body}
              </p>
            </div>

            {item.island === 'cross-repo-ship' ? (
              <VizSurface aspect="none">
                <CrossRepoShip client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'session-timeline' ? (
              <VizSurface>
                <SessionTimeline client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'session-durability' ? (
              <VizSurface>
                <SessionDurability client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'feedback-loop' ? (
              <VizSurface aspect="none">
                <FeedbackLoop client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'memory-distill' ? (
              <VizSurface>
                <MemoryDistill client:visible className="mx-auto" />
              </VizSurface>
            ) : item.island === 'policy-gate' ? (
              <VizSurface aspect="none">
                <PolicyGate client:visible className="mx-auto" />
              </VizSurface>
            ) : (
              <VizPlaceholder label={item.viz ?? ''} ratio="aspect-[16/9]" />
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
