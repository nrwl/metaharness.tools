---
// Ambient starfield backdrop for the hero. Framework-free (a plain canvas +
// inline script, matching HeroV3's own scroll script) since it's purely
// decorative. Faint twinkling stars drift slowly; every so often two nearby
// stars link with a line that eases in, lingers, and fades out — "here and
// there", never a constant mesh. Theme-aware, DPR-crisp, static under
// prefers-reduced-motion. Masked to fade at the edges, and tagged
// data-hero-fade so it fades on scroll with the headline.
---

<canvas
  data-hero-bg
  data-hero-fade
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 z-0 h-full w-full"
  style="mask-image: radial-gradient(120% 90% at 50% 42%, black 32%, transparent 82%); -webkit-mask-image: radial-gradient(120% 90% at 50% 42%, black 32%, transparent 82%);"
></canvas>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-hero-bg]');
  const ctx = canvas?.getContext('2d');

  if (canvas && ctx) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    // Palette resolves per theme. Stars are neutral; brighter/fainter tuned so
    // they stay legible on either background.
    let baseRGB = '150, 150, 150';
    let starAlpha = 0.45;
    let linkAlpha = 0.32;
    const readTheme = () => {
      const dark = document.documentElement.classList.contains('dark');
      baseRGB = dark ? '190, 190, 190' : '120, 120, 120';
      starAlpha = dark ? 0.4 : 0.42;
      linkAlpha = dark ? 0.3 : 0.32;
    };
    readTheme();

    interface Star {
      x: number;
      y: number;
      vx: number;
      vy: number;
      r: number;
      base: number; // baseline brightness 0..1
      tw: number; // twinkle phase
      twSpeed: number; // twinkle speed
    }
    interface Link {
      a: number;
      b: number;
      age: number; // seconds
      dur: number; // total lifetime, seconds
    }

    let w = 0;
    let h = 0;
    let dpr = 1;
    let stars: Star[] = [];
    let links: Link[] = [];
    const CONNECT_DIST = 210; // px; only stars this close can link
    const MAX_LINKS = 5;

    const rand = (min: number, max: number) => min + Math.random() * (max - min);

    const build = () => {
      const rect = canvas.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      // Star density scales with area, capped so big screens stay calm.
      const count = Math.min(180, Math.max(40, Math.round((w * h) / 9000)));
      stars = Array.from({ length: count }, () => ({
        x: rand(0, w),
        y: rand(0, h),
        vx: rand(-0.06, 0.06),
        vy: rand(-0.06, 0.06),
        r: rand(0.6, 1.7),
        base: rand(0.35, 1),
        tw: rand(0, Math.PI * 2),
        twSpeed: rand(0.5, 1.6),
      }));
      links = [];
    };

    const alreadyLinked = (i: number, j: number) =>
      links.some(
        (l) => (l.a === i && l.b === j) || (l.a === j && l.b === i),
      );

    // Occasionally connect one star to a nearby neighbour.
    const spawnLink = () => {
      if (links.length >= MAX_LINKS) return;
      const i = Math.floor(Math.random() * stars.length);
      const candidates: number[] = [];
      for (let j = 0; j < stars.length; j++) {
        if (j === i || alreadyLinked(i, j)) continue;
        const dx = stars[i].x - stars[j].x;
        const dy = stars[i].y - stars[j].y;
        if (dx * dx + dy * dy < CONNECT_DIST * CONNECT_DIST) candidates.push(j);
      }
      if (!candidates.length) return;
      const b = candidates[Math.floor(Math.random() * candidates.length)];
      links.push({ a: i, b, age: 0, dur: rand(4, 7) }); // slow: 4–7s each
    };

    let last = 0;
    let nextSpawnAt = 0;

    const draw = (now: number) => {
      const dt = last ? Math.min(0.05, (now - last) / 1000) : 0;
      last = now;
      const t = now / 1000;

      ctx.clearRect(0, 0, w, h);

      // Per-star boost while it's an endpoint of an active link.
      const boost = new Float32Array(stars.length);

      // Links behind the stars; sine envelope eases in then out.
      ctx.lineWidth = 1;
      for (let k = links.length - 1; k >= 0; k--) {
        const l = links[k];
        const env = Math.sin((l.age / l.dur) * Math.PI); // 0 → 1 → 0
        const a = stars[l.a];
        const b = stars[l.b];
        ctx.strokeStyle = `rgba(${baseRGB}, ${env * linkAlpha})`;
        ctx.beginPath();
        ctx.moveTo(a.x, a.y);
        ctx.lineTo(b.x, b.y);
        ctx.stroke();
        if (env > boost[l.a]) boost[l.a] = env;
        if (env > boost[l.b]) boost[l.b] = env;

        l.age += dt;
        if (l.age >= l.dur) links.splice(k, 1);
      }

      // Stars: twinkle, plus a gentle glow when connected.
      for (let i = 0; i < stars.length; i++) {
        const s = stars[i];
        const twinkle = 0.7 + 0.3 * Math.sin(t * s.twSpeed + s.tw);
        const a = s.base * starAlpha * twinkle;

        if (boost[i] > 0.01) {
          ctx.fillStyle = `rgba(${baseRGB}, ${0.12 * boost[i]})`;
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r + 3.5 * boost[i], 0, Math.PI * 2);
          ctx.fill();
        }

        ctx.fillStyle = `rgba(${baseRGB}, ${Math.min(1, a + boost[i] * 0.4)})`;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r + boost[i] * 0.6, 0, Math.PI * 2);
        ctx.fill();

        // Slow drift; wrap softly at the edges.
        s.x += s.vx;
        s.y += s.vy;
        if (s.x < -10) s.x = w + 10;
        else if (s.x > w + 10) s.x = -10;
        if (s.y < -10) s.y = h + 10;
        else if (s.y > h + 10) s.y = -10;
      }

      if (now >= nextSpawnAt) {
        spawnLink();
        nextSpawnAt = now + rand(700, 1800);
      }
    };

    let raf = 0;
    let running = false;
    const loop = (now: number) => {
      draw(now);
      raf = requestAnimationFrame(loop);
    };
    const start = () => {
      if (running) return;
      running = true;
      last = 0;
      raf = requestAnimationFrame(loop);
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(raf);
    };

    const render = () => {
      build();
      if (reduce.matches) {
        stop();
        draw(0); // single static frame: just the starfield
      } else {
        start();
      }
    };

    render();

    // Rebuild on resize (debounced), re-read palette on theme toggle.
    let resizeT = 0;
    window.addEventListener(
      'resize',
      () => {
        window.clearTimeout(resizeT);
        resizeT = window.setTimeout(render, 150);
      },
      { passive: true },
    );
    reduce.addEventListener('change', render);
    new MutationObserver(() => {
      readTheme();
      if (reduce.matches) draw(0);
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });

    // Don't animate offscreen / on hidden tabs.
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else if (!reduce.matches) start();
    });
  }
</script>
