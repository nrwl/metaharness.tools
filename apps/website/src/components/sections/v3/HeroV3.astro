---
import { MetaHarnessLayers } from '@metaharness/animations';
import VizSurface from '../../VizSurface.astro';
import HeroDotText from './HeroDotText.astro';
---

<section
  id="top"
  class="relative flex min-h-[calc(100svh-61px)] flex-col overflow-hidden px-6"
>
  <div class="relative z-10 flex flex-1 flex-col justify-center">
    <div data-hero-fade class="mx-auto w-full max-w-5xl">
      <HeroDotText />
      <p
        data-hero-subtitle
        class="mt-6 max-w-4xl text-2xl text-balance text-neutral-600 sm:text-3xl dark:text-neutral-400"
      >
        Meta-harnesses fill the gaps your AI agent harness leaves.
      </p>
    </div>
  </div>

  <div
    data-hero-fade
    class="relative z-10 flex flex-col items-center gap-1 pb-6 font-mono text-xs uppercase tracking-[0.2em] text-neutral-500 dark:text-neutral-600"
  >
    <span>Scroll down</span>
    <span aria-hidden="true">&darr;</span>
  </div>
</section>

<script>
  const faders = [
    ...document.querySelectorAll<HTMLElement>('[data-hero-fade]'),
  ];
  if (faders.length) {
    const update = () => {
      const progress = Math.min(
        1,
        Math.max(0, window.scrollY / (window.innerHeight * 0.5)),
      );
      for (const el of faders) {
        el.style.opacity = String(1 - progress);
        el.style.transform = `translateY(${progress * -16}px)`;
      }
    };

    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
        }
      },
      { passive: true },
    );
    window.addEventListener('resize', update, { passive: true });
    update();
  }

  // Subtitle eases in once the headline dots finish forming.
  const subtitle = document.querySelector<HTMLElement>('[data-hero-subtitle]');
  if (subtitle) {
    const reveal = () => subtitle.classList.add('is-in');
    document.addEventListener('dottext:done', reveal, { once: true });
    // Safety net in case the signal never arrives (e.g. no canvas support).
    window.setTimeout(reveal, 3000);
  }
</script>

<style>
  [data-hero-subtitle] {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease;
  }
  [data-hero-subtitle].is-in {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    [data-hero-subtitle] {
      transition: opacity 0.2s ease;
      transform: none;
    }
  }
</style>

<section id="what-is" class="px-6 pt-20 pb-16 md:pt-28 md:pb-24">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl">
      <h2
        class="text-3xl font-semibold tracking-tight text-neutral-900 sm:text-5xl dark:text-neutral-50"
      >
        Meta-harnesses are the missing layer.
      </h2>
      <p
        class="mt-8 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      >
        Agentic engineering changes how developers work. The focus shifts from
        low-level implementation details to system architecture and data flow,
        from working in a single repository to orchestrating many at once,
        managing sessions and context across implementation tasks. Everyone
        hand-stitches their own workflows to make existing harnesses adapt to
        this new way of working. Just like everyone built around React until the
        meta-frameworks arrived. The meta-harness is <mark>like the
        meta-frameworks, that layer that comes with batteries included</mark>.
      </p>
    </div>
  </div>

  <div class="-mx-6 mt-1 max-w-2xl min-w-0 cursor-default md:mx-auto md:mt-2">
    <VizSurface aspect="aspect-[3/2]">
      <MetaHarnessLayers
        client:load
        variant="simple"
        stage={2}
        paused
        width={630}
        height={420}
        className="mx-auto"
      />
    </VizSurface>
  </div>
</section>
