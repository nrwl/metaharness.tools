---
import { MetaHarnessLayers } from '@metaharness/animations';
import VizSurface from '../../VizSurface.astro';
---

<section id="top" class="relative flex min-h-[calc(100svh-61px)] flex-col px-6">
  <div class="flex flex-1 flex-col justify-center">
    <div data-hero-fade class="mx-auto w-full max-w-5xl">
      <h1
        class="text-6xl font-semibold tracking-tight text-neutral-900 sm:text-8xl dark:text-neutral-50"
      >
        The Connected Agent
      </h1>
      <p
        class="mt-6 max-w-2xl text-xl text-neutral-600 sm:text-2xl dark:text-neutral-400"
      >
        Meta-harnesses fill the gaps your harness leaves.
      </p>
    </div>
  </div>

  <div
    data-hero-fade
    class="flex flex-col items-center gap-1 pb-6 font-mono text-xs uppercase tracking-[0.2em] text-neutral-500 dark:text-neutral-600"
  >
    <span>Scroll down</span>
    <span aria-hidden="true">&darr;</span>
  </div>
</section>

<script>
  const faders = [
    ...document.querySelectorAll<HTMLElement>('[data-hero-fade]'),
  ];
  if (faders.length) {
    const update = () => {
      const progress = Math.min(
        1,
        Math.max(0, window.scrollY / (window.innerHeight * 0.5)),
      );
      for (const el of faders) {
        el.style.opacity = String(1 - progress);
        el.style.transform = `translateY(${progress * -16}px)`;
      }
    };

    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => {
            update();
            ticking = false;
          });
        }
      },
      { passive: true },
    );
    window.addEventListener('resize', update, { passive: true });
    update();
  }
</script>

<section id="what-is" class="px-6 pt-20 pb-16 md:pt-28 md:pb-24">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl">
      <h2
        class="text-3xl font-semibold tracking-tight text-neutral-900 sm:text-5xl dark:text-neutral-50"
      >
        Meta-harnesses elevate the primitive.
      </h2>
      <p
        class="mt-8 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      >
        A harness is a primitive. Claude Code, Codex, and OpenCode are excellent
        at one thing: turning a model into an agent that acts inside a repo.
        Your work, meanwhile, is moving up a level: the whole stack, many
        repositories, many sessions at once. Everyone hand-stitches workflows to
        bridge that gap, just like everyone built around React until the
        meta-frameworks arrived. <strong
          class="font-semibold text-neutral-900 dark:text-neutral-50"
          >The meta-harness is that layer: batteries included for agentic work.</strong
        >
      </p>
    </div>
  </div>

  <div class="mx-auto mt-6 max-w-5xl min-w-0 md:mt-8">
    <VizSurface>
      <MetaHarnessLayers
        client:visible
        variant="simple"
        playOnce
        height={420}
        className="mx-auto"
      />
    </VizSurface>
  </div>
</section>
