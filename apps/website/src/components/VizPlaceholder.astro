---
interface Props {
  label: string;
  ratio?: string;
}

const { label, ratio = 'aspect-[16/9]' } = Astro.props;
---

<div
  class={`${ratio} flex max-h-[28rem] w-full items-center justify-center rounded-lg border border-dashed border-neutral-300 bg-neutral-100/60 dark:border-neutral-800 dark:bg-neutral-900/30`}
>
  <span
    class="px-6 text-center font-mono text-xs tracking-widest text-neutral-500 dark:text-neutral-600"
  >
    viz: {label}
  </span>
</div>
