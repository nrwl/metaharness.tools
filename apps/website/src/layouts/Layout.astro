---
import '../styles/global.css';
import ComingSoon from '../components/ComingSoon.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  ogType?: string;
  canonical?: string;
}

// Dev server: real site unless explicitly gated with COMING_SOON=true.
// Production builds: gated unless explicitly unlocked with COMING_SOON=false.
const comingSoon = import.meta.env.DEV
  ? process.env.COMING_SOON === 'true'
  : process.env.COMING_SOON !== 'false';

const {
  title = 'metaharness.tools',
  description = 'Understanding meta harnesses.',
  noindex = false,
  image = '/og.png',
  ogType = 'website',
  canonical,
} = Astro.props;

const pageTitle = comingSoon ? 'metaharness.tools' : title;
const pageDescription = comingSoon ? 'Coming soon.' : description;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
const canonicalHref = canonicalUrl.toString();
const imageHref = imageUrl.toString();
const robots = comingSoon || noindex ? 'noindex,nofollow' : undefined;
const organization = {
  '@type': 'Organization',
  '@id': 'https://metaharness.tools/#organization',
  name: 'Nx',
  url: 'https://nx.dev',
  sameAs: ['https://github.com/nrwl', 'https://twitter.com/NxDevTools'],
};
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://metaharness.tools/#website',
      name: 'metaharness.tools',
      url: 'https://metaharness.tools',
      description: pageDescription,
      publisher: { '@id': organization['@id'] },
    },
    organization,
    {
      '@type': 'TechArticle',
      headline: pageTitle,
      description: pageDescription,
      about: 'AI agent meta-harness',
      author: { '@id': organization['@id'] },
      publisher: { '@id': organization['@id'] },
      url: canonicalHref,
      mainEntityOfPage: canonicalHref,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    {robots && <meta name="robots" content={robots} />}
    {
      !comingSoon && (
        <>
          <link rel="canonical" href={canonicalHref} />
          <meta property="og:type" content={ogType} />
          <meta property="og:site_name" content="metaharness.tools" />
          <meta property="og:title" content={pageTitle} />
          <meta property="og:description" content={pageDescription} />
          <meta property="og:url" content={canonicalHref} />
          <meta property="og:image" content={imageHref} />
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
          <meta
            property="og:image:alt"
            content="metaharness.tools, an educational reference on AI agent meta-harnesses"
          />
          <meta name="twitter:card" content="summary_large_image" />
          <meta name="twitter:site" content="@NxDevTools" />
          <meta name="twitter:creator" content="@NxDevTools" />
          <meta name="twitter:title" content={pageTitle} />
          <meta name="twitter:description" content={pageDescription} />
          <meta name="twitter:image" content={imageHref} />
          <meta name="theme-color" content="#0a0a0a" />
          <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(structuredData)}
          />
        </>
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        try {
          // Theme is 'light' | 'dark' | 'system'; unset defaults to 'system'.
          var t = localStorage.getItem('theme') || 'system';
          var dark =
            t === 'dark' ||
            (t !== 'light' &&
              window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.classList.toggle('dark', dark);
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    {comingSoon ? <ComingSoon /> : <slot />}
  </body>
</html>
