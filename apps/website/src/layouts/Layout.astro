---
import '../styles/global.css';
import SectionAnchors from '../components/SectionAnchors.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  ogType?: string;
  canonical?: string;
}

const {
  title = 'metaharness.tools',
  description = 'Understanding meta harnesses.',
  noindex = false,
  image = '/og.png',
  ogType = 'website',
  canonical,
} = Astro.props;

const pageTitle = title;
const pageDescription = description;
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
const canonicalHref = canonicalUrl.toString();
const imageHref = imageUrl.toString();

// Google Analytics — load only in production builds so local dev doesn't pollute metrics.
const isProd = import.meta.env.PROD;
const gaMeasurementId = 'G-HN13G1HPCR';
const gaInit = `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaMeasurementId}');`;
const robots = noindex ? 'noindex,nofollow' : undefined;
// Site launch date; dateModified is stamped at build time.
const datePublished = '2026-07-02';
const dateModified = new Date().toISOString().split('T')[0];
const organization = {
  '@type': 'Organization',
  '@id': 'https://metaharness.tools/#organization',
  name: 'Nx',
  url: 'https://nx.dev',
  sameAs: ['https://github.com/nrwl', 'https://twitter.com/NxDevTools'],
};
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://metaharness.tools/#website',
      name: 'metaharness.tools',
      url: 'https://metaharness.tools',
      description: pageDescription,
      publisher: { '@id': organization['@id'] },
    },
    organization,
    {
      '@type': 'DefinedTerm',
      '@id': 'https://metaharness.tools/#meta-harness',
      name: 'Meta-harness',
      description:
        'A layer above AI agent harnesses that spans repositories, sessions, and time: orchestrating and swapping harnesses, coordinating cross-repo work, persisting session memory, and enforcing organizational policy.',
      url: 'https://metaharness.tools/',
    },
    {
      '@type': 'TechArticle',
      headline: pageTitle,
      description: pageDescription,
      about: { '@id': 'https://metaharness.tools/#meta-harness' },
      author: { '@id': organization['@id'] },
      publisher: { '@id': organization['@id'] },
      datePublished,
      dateModified,
      url: canonicalHref,
      mainEntityOfPage: canonicalHref,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalHref} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="metaharness.tools" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:image" content={imageHref} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="metaharness.tools, an educational reference on AI agent meta-harnesses"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@NxDevTools" />
    <meta name="twitter:creator" content="@NxDevTools" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imageHref} />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#0a0a0a"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#ffffff"
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="text/plain"
      href="/llms-full.txt"
      title="LLM-friendly full page text"
    />
    {
      isProd && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
          />
          <script is:inline set:html={gaInit} />
        </>
      )
    }
    <script is:inline>
      (function () {
        try {
          // Theme is 'light' | 'dark' | 'system'; unset defaults to 'system'.
          var t = localStorage.getItem('theme') || 'system';
          var dark =
            t === 'dark' ||
            (t !== 'light' &&
              window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.classList.toggle('dark', dark);
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <slot />
    <SectionAnchors />
  </body>
</html>
