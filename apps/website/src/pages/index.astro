---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import FrameworkWars from '../components/sections/FrameworkWars.astro';
import WhatIsHarness from '../components/sections/WhatIsHarness.astro';
import HarnessVsMeta from '../components/sections/HarnessVsMeta.astro';
import WhatMetaAdds from '../components/sections/WhatMetaAdds.astro';
import Recap from '../components/sections/Recap.astro';
import Infrastructure from '../components/sections/Infrastructure.astro';
import CloudAgents from '../components/sections/CloudAgents.astro';
import Landscape from '../components/sections/Landscape.astro';
import Finale from '../components/sections/Finale.astro';
import Footer from '../components/sections/Footer.astro';

const title =
  'metaharness.tools | Everything you need to know about meta-harnesses';
const description =
  'An educational reference on AI agent meta-harnesses: the layer above your harnesses that spans repos, sessions, and time. What they are, what they add, and why.';
---

<Layout title={title} description={description}>
  <Nav />
  <main class="bg-neutral-950 text-neutral-100">
    <Hero />
    <Problem />
    <FrameworkWars />
    <WhatIsHarness />
    <HarnessVsMeta />
    <WhatMetaAdds />
    <Recap />
    <Infrastructure />
    <CloudAgents />
    <Landscape />
    <Finale />
  </main>
  <Footer />
</Layout>
