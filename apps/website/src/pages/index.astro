---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroV3 from '../components/sections/v3/HeroV3.astro';
import SectionRailV3 from '../components/sections/v3/SectionRailV3.astro';
import SingleRepoV3 from '../components/sections/v3/SingleRepoV3.astro';
import WorkShiftV3 from '../components/sections/v3/WorkShiftV3.astro';
import LostMemoryV3 from '../components/sections/v3/LostMemoryV3.astro';
import AnswerV3 from '../components/sections/v3/AnswerV3.astro';
import WhatMetaHarnessV3 from '../components/sections/v3/WhatMetaHarnessV3.astro';
import LandscapeV3 from '../components/sections/v3/LandscapeV3.astro';
import FaqV3 from '../components/sections/v3/FaqV3.astro';
import Finale from '../components/sections/Finale.astro';
import Footer from '../components/sections/Footer.astro';

const title =
  'What Is a Meta-Harness? The Optimization Layer Around AI Coding Agents';
const description =
  'What is a meta-harness? The layer that optimizes the harness around AI coding agents like Claude Code and Codex: feedback loops, memory, and rules that make agents improve over time.';

const navLinks = [
  { href: '#single-repo', label: 'The challenge' },
  { href: '#answer', label: 'The answer' },
  { href: '#capabilities', label: 'What it does' },
  { href: '#landscape', label: 'Landscape' },
];
---

<Layout title={title} description={description}>
  <Nav links={navLinks} />
  <main
    class="bg-white text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100"
  >
    <SectionRailV3 />
    <HeroV3 />
    <SingleRepoV3 />
    <WorkShiftV3 />
    <LostMemoryV3 />
    <AnswerV3 />
    <WhatMetaHarnessV3 />
    <LandscapeV3 />
    <FaqV3 />
    <Finale />
  </main>
  <Footer />
</Layout>
