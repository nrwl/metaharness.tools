---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroV2 from '../components/sections/v2/HeroV2.astro';
import WhyV2 from '../components/sections/v2/WhyV2.astro';
import WorkShiftV2 from '../components/sections/v2/WorkShiftV2.astro';
import BarrierV2 from '../components/sections/v2/BarrierV2.astro';
import CapabilitiesV2 from '../components/sections/v2/CapabilitiesV2.astro';
import KnowledgeV2 from '../components/sections/v2/KnowledgeV2.astro';
import LandscapeV2 from '../components/sections/v2/LandscapeV2.astro';
import Finale from '../components/sections/Finale.astro';
import Footer from '../components/sections/Footer.astro';

const title = 'metaharness.tools | v2 proposal';
const description =
  'Alternative, definition-first page structure for metaharness.tools: what a meta-harness is, why you would need one, and what it does.';

const navLinks = [
  { href: '#why', label: 'Why' },
  { href: '#work-shift', label: 'Your work' },
  { href: '#barrier', label: 'The barrier' },
  { href: '#capabilities', label: 'Capabilities' },
  { href: '#knowledge', label: 'Knowledge' },
  { href: '#landscape', label: 'Landscape' },
];
---

<Layout title={title} description={description} noindex={true}>
  <Nav links={navLinks} />
  <main class="bg-neutral-950 text-neutral-100">
    <HeroV2 />
    <WhyV2 />
    <WorkShiftV2 />
    <BarrierV2 />
    <CapabilitiesV2 />
    <KnowledgeV2 />
    <LandscapeV2 />
    <Finale />
  </main>
  <Footer />
</Layout>
