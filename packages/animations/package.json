{
  "name": "@metaharness/animations",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Canvas-based, self-running visualizations for metaharness.tools, developed in isolation with Storybook.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "d3-force": "^3.0.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "typescript": "^5.7.3",
    "vite": "^8.1.3"
  },
  "nx": {
    "targets": {
      "build-storybook": {
        "outputs": ["{projectRoot}/storybook-static"],
        "inputs": ["production", "^production"],
        "cache": true
      },
      "typecheck": {
        "inputs": ["default", "^production"],
        "cache": true
      }
    }
  }
}
